{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "*.md",
      "node_modules/**",
      "functions/**",
      ".git/**",
      "*.log",
      "set-cors.js",
      "cors.json",
      "assets/images/2.JPG",
      "assets/ext.pdf",
      "assets/ABOUT.docx",
      "assets/Rules.docx",
      "assets/KHASI.docx",
      "assets/index.html",
      "seed-update.js",
      "seed-update.html",
      "unmatched-report.js",
      "package-lock.json",
      "package.json",
      "Sfs-report-card/**",
      "FEES/**",
      "RP/**",
      "routine-app/.git/**",
      "routine-app/seed.js",
      "routine-app/firestore.rules",
      "routine-app/improvement.txt",
      "serviceAccountKey.json",
      "*.txt",
      "session-summary-*.txt",
      "WORK-LOG-*.md",
      "fix-hero.html"
    ],
    "rewrites": [
      {
        "source": "!routine-app/**",
        "destination": "/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|eot)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=2592000, must-revalidate" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
