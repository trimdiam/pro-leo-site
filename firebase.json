{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "predeploy": [
      "node scripts/bump-sw-cache.js"
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "*.md",
      "docs/**",
      "node_modules/**",
      "functions/**",
      "scripts/**",
      ".git/**",
      "*.log",
      "set-cors.js",
      "cors.json",
      "assets/images/2.JPG",
      "assets/ext.pdf",
      "assets/ABOUT.docx",
      "assets/Rules.docx",
      "assets/KHASI.docx",
      "assets/index.html",
      "seed-update.js",
      "seed-update.html",
      "unmatched-report.js",
      "package-lock.json",
      "package.json",

      "Sfs-report-card/seed-demo.html",
      "FEES/**",
      "RP/**",
      "routine-app/.git/**",
      "routine-app/seed.js",
      "routine-app/firestore.rules",
      "routine-app/improvement.txt",
      "assessment-app/.git/**",
      "assessment-app/*.md",
      "assessment-app/tools/**",
      "assessment-app/demo-report-card.html",
      "assessment-app/demo-report-card-legal.html",
      "**/.claude/**",
      "serviceAccountKey.json",
      "*.txt",
      "session-summary-*.txt",
      "WORK-LOG-*.md",
      "fix-hero.html"
    ],
    "version": {
      "releases": {
        "count": 5
      }
    },
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "Content-Security-Policy", "value": "frame-ancestors 'self'" }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|eot)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "assessment-app/**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "emulators": {
    "firestore": { "port": 8080 },
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
