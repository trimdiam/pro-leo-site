rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Role helpers ─────────────────────────────────────────────────
    function isRole(role) {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    // office staff may be stored as 'office' or 'office_staff'
    function isOffice()    { return isRole('office') || isRole('office_staff'); }
    function isAnyStaff()  { return isRole('admin') || isOffice() || isRole('teacher'); }
    function isAdmin()     { return isRole('admin'); }
    function isOwner()     { return request.auth != null && request.auth.uid == resource.id; }

    // ── Users ────────────────────────────────────────────────────────
    // Each user manages their own doc; admin can read all.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read:        if isAdmin();
      allow write:       if isAdmin();
    }

    // ── Students ─────────────────────────────────────────────────────
    match /students/{docId} {
      allow read:  if isAnyStaff() ||
        (request.auth != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId == docId) ||
        // Sibling system: allow a student to read linked family members
        (request.auth != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student' &&
         resource.data.familyId != null &&
         resource.data.familyId ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId);
      allow write: if isAdmin() || isOffice();
    }

    // ── Daily attendance (with month-locking guard) ───────────────────
    match /attendance_daily/{docId} {
      allow read:  if isAnyStaff() || request.auth != null;
      allow write: if request.auth != null
        && (isRole('teacher') || isAdmin())
        && (isDailyWriteAllowed(database, docId) || isAdmin());
    }

    // ── Monthly attendance snapshots (locking workflow) ───────────────
    match /attendance_monthly/{docId} {
      allow read:   if isAnyStaff();
      allow create: if isAnyStaff();
      allow update: if isAnyStaff() && isMonthlyUpdateAllowed(database);
      allow delete: if false;
    }

    // ── Fee transactions ─────────────────────────────────────────────
    match /fee_transactions/{docId} {
      allow read: if isAnyStaff() ||
        (request.auth != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId ==
         resource.data.studentId);
      allow write: if isAdmin() || isOffice();
    }

    // ── Fees (older collection — student notification center reads) ───
    match /fees/{docId} {
      allow read:  if isAnyStaff() ||
        (request.auth != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId ==
         resource.data.studentId);
      allow write: if isAdmin() || isOffice();
    }

    // ── Fee structure ─────────────────────────────────────────────────
    match /fee_structure/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin() || isOffice();
    }

    // ── Homework ─────────────────────────────────────────────────────
    match /homework/{docId} {
      allow read:  if request.auth != null;
      allow write: if isRole('teacher') || isAdmin();
    }

    // ── Notices ──────────────────────────────────────────────────────
    match /notices/{docId} {
      allow read:  if true;
      allow write: if isAdmin() || isRole('teacher');
    }

    // ── Public-read / admin-write collections ─────────────────────────
    match /events/{docId}         { allow read: if true; allow write: if isAdmin(); }
    match /gallery/{docId}        { allow read: if true; allow write: if isAdmin(); }
    match /announcements/{docId}  { allow read: if true; allow write: if isAdmin(); }
    match /teachers/{docId}       { allow read: if true; allow write: if isAdmin(); }
    match /classes/{docId}        { allow read: if isAnyStaff(); allow write: if isAdmin(); }
    match /settings/{docId}       { allow read: if true; allow write: if isAdmin(); }
    match /public_settings/{docId}{ allow read: if true; allow write: if isAdmin(); }
    match /holidays/{docId}       { allow read: if true; allow write: if isAdmin(); }
    match /academicSessions/{docId}{ allow read: if true; allow write: if isAdmin(); }
    match /why_choose_us/{docId}  { allow read: if true; allow write: if isAdmin(); }
    match /school_leaders/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /quotes/{docId}         { allow read: if true; allow write: if isAdmin(); }

    // ── Admissions: public create; staff reads/updates ────────────────
    match /admissions/{docId} {
      allow create:        if true;
      allow read, update:  if isAnyStaff();
      allow delete:        if isAdmin();
    }

    // ── Contacts: public create; admin reads ─────────────────────────
    match /contacts/{docId} {
      allow create:     if true;
      allow read, write: if isAdmin();
    }

    // ── Leave applications ───────────────────────────────────────────
    match /leave_applications/{docId} {
      allow create: if request.auth != null;
      allow read:   if isAnyStaff();
      allow update: if isAdmin();
    }

    // ── New account links (Google sign-in self-linking) ───────────────
    match /newAccountLinks/{docId} {
      allow create: if request.auth != null;
      allow read:   if isAdmin();
    }

    // ── Marks (mark entry system — subject & class teachers) ─────────
    match /marks/{termDoc}/students/{studentId} {
      allow read:  if isAnyStaff() ||
        (request.auth != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId == studentId &&
         resource.data.releasedToStudent == true);
      allow write: if isRole('teacher') || isAdmin();
    }

    // ── Routine / Timetable ──────────────────────────────────────────
    match /routine/{document=**} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Subjects ─────────────────────────────────────────────────────
    match /subjects/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Student messages ─────────────────────────────────────────────
    match /student_messages/{docId} {
      allow read:   if isAnyStaff() ||
        (request.auth != null &&
         resource.data.to == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId);
      allow create: if request.auth != null;
      allow update, delete: if isAnyStaff();
    }

    // ── Assessment sessions ───────────────────────────────────────────
    match /assessment_sessions/{docId} {
      allow read:  if isAnyStaff();
      allow write: if isRole('teacher') || isAdmin();
    }

    // ── Monthly analytics ─────────────────────────────────────────────
    match /monthly_analytics/{docId} {
      allow read:  if isAnyStaff();
      allow write: if isRole('teacher') || isAdmin();
    }

    // ── Weak student flags ────────────────────────────────────────────
    match /weak_students/{docId} {
      allow read:  if isAnyStaff();
      allow write: if isRole('teacher') || isAdmin();
    }

    // ── Student academic profiles ─────────────────────────────────────
    match /student_profiles/{docId} {
      allow read:  if isAnyStaff() ||
        (request.auth != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId == docId);
      allow write: if isRole('teacher') || isAdmin();
    }

    // ── Admin notifications ──────────────────────────────────────────
    match /admin_notifications/{docId} {
      allow read, write: if isAdmin() || isOffice();
    }

    // ── Report Cards ──────────────────────────────────────────────────
    match /report_cards/{docId} {
      allow read, write: if isAdmin();
      allow read:        if isAnyStaff();
      allow read:        if request.auth != null
        && isRole('student')
        && resource.data.studentId ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId
        && resource.data.status == 'released';
    }

  }

  // ── Helper: is the daily doc's month unlocked? ───────────────────────
  // docId format: "{classNum}_{YYYY-MM-DD}"
  function isDailyWriteAllowed(database, docId) {
    let parts    = docId.split('_');
    let classNum = parts[0];
    let datePart = parts[1];
    let yyyy     = datePart.split('-')[0];
    let mm       = datePart.split('-')[1];
    let monthKey = classNum + '_' + yyyy + '_' + mm;
    let monthPath = /databases/$(database)/documents/attendance_monthly/$(monthKey);
    return !exists(monthPath) || get(monthPath).data.get('status', '') != 'locked';
  }

  // ── Helper: monthly snapshot update rules ────────────────────────────
  //   draft  → any staff can update (regenerate)
  //   locked → only admin/super_admin can update
  //   unlock (locked→draft) → only super_admin
  function isMonthlyUpdateAllowed(database) {
    let currentlyLocked = resource.data.status == 'locked';
    let tryingToUnlock  = request.resource.data.status == 'draft';
    let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    return !currentlyLocked
      || (role == 'admin' || role == 'super_admin');
  }
}
