rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public admission form ─────────────────────────────────────
    // Anyone can CREATE (submit a new application).
    // Only authenticated staff/admin can read or update existing ones.
    match /admissions/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── Homepage CMS ──────────────────────────────────────────────
    // Public visitors need to READ public_settings/homepage to render
    // the dynamic hero/stats/announcement/feature-cards.
    // Only authenticated admins can WRITE.
    match /public_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Settings (about, mission, vision, etc.) ───────────────────
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Public-read collections ───────────────────────────────────
    match /events/{docId}        { allow read: if true; allow write: if request.auth != null; }
    match /announcements/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /why_choose_us/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /school_leaders/{docId}{ allow read: if true; allow write: if request.auth != null; }
    match /gallery/{docId}       { allow read: if true; allow write: if request.auth != null; }
    match /quotes/{docId}        { allow read: if true; allow write: if request.auth != null; }

    // ── Monthly attendance snapshots ──────────────────────────────
    // READ  : any authenticated user.
    // CREATE: any authenticated user (teachers generating snapshots).
    // UPDATE: three-tier rule —
    //   • Draft docs  → any authenticated user can update (regenerate).
    //   • Locked docs → only admin/super_admin can update (approve, correct).
    //   • Unlocking   → only super_admin can set status back to 'draft'.
    // DELETE: never allowed.
    match /attendance_monthly/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && isMonthlyUpdateAllowed(database);
      allow delete: if false;
    }

    // ── Daily attendance records ───────────────────────────────────
    // Teachers: read always; write only when the month is not locked.
    // Admins  : can still write (corrections) when month is locked.
    // Derive monthly doc ID from daily doc ID:
    //   "{classNum}_{YYYY-MM-DD}" → "{classNum}_{YYYY_MM}"
    match /attendance_daily/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (isDailyWriteAllowed(database, docId)
            || isAdminOrSuper(database));
    }

    // ── Academic Sessions ─────────────────────────────────────────
    // Public read so the session selector works without auth.
    // Only authenticated users (admins) can write.
    match /academicSessions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── All other documents — require authentication ───────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }

  // docId format: "10_2026-05-16"  →  monthly key: "10_2026_05"
  function isDailyWriteAllowed(database, docId) {
    let parts    = docId.split('_');
    let classNum = parts[0];
    let datePart = parts[1];
    let yyyy     = datePart.split('-')[0];
    let mm       = datePart.split('-')[1];
    let monthKey = classNum + '_' + yyyy + '_' + mm;
    let monthDoc = get(/databases/$(database)/documents/attendance_monthly/$(monthKey));
    return !monthDoc.exists() || monthDoc.data().status != 'locked';
  }

  // Returns true if the authenticated user has role 'admin' or 'super_admin'.
  function isAdminOrSuper(database) {
    let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
    let role    = userDoc.data().role;
    return role == 'admin' || role == 'super_admin';
  }

  // Monthly snapshot update rules:
  //   • Draft  → any authenticated user.
  //   • Locked → admin or super_admin only (can lock / correct).
  //   • Unlock (locked → draft) → super_admin only.
  function isMonthlyUpdateAllowed(database) {
    let currentlyLocked = resource.data.status == 'locked';
    let tryingToUnlock  = request.resource.data.status == 'draft';
    let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data().role;
    return !currentlyLocked
      || ((role == 'admin' || role == 'super_admin') && (!tryingToUnlock || role == 'super_admin'));
  }
}
